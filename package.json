{
  "name": "isomorphic",
  "version": "7.6.2",
  "description": "A nextjs template to build dashboard",
  "private": true,
  "scripts": {
    "dev": "turbo dev --filter=starter",
    "gen-module": "node scripts/gen-module.mjs",
    "kb:embed": "node --env-file=apps/perpos/.env.local scripts/kb-embed.mjs",
    "skills:install": "node scripts/manage-skills.mjs",
    "lint": "turbo lint --filter=starter",
    "type:check": "turbo type:check --filter=starter",
    "format": "prettier --write \"apps/**/*.{ts,tsx}\" \"services/**/src/**/*.ts\"",
    "format:check": "prettier --check \"apps/**/*.{ts,tsx}\" \"services/**/src/**/*.ts\"",
    "build": "turbo build --filter=starter",
    "start": "turbo start --filter=starter",
    "clean": "turbo clean && rm -rf node_modules .turbo",
    "cache:clean": "turbo cache:clean && rm -rf .turbo",
    "starter:dev": "turbo dev --filter=starter",
    "starter:lint": "turbo lint --filter=starter",
    "starter:build": "turbo build --filter=starter",
    "starter:start": "turbo start --filter=starter",
    "starter:clean": "turbo clean --filter=starter",
    "api:dev": "turbo dev --filter=api",
    "api:build": "turbo build --filter=api",
    "pdf:dev": "turbo dev --filter=pdf-renderer",
    "pdf:build": "turbo build --filter=pdf-renderer",
    "ocr-worker:dev": "turbo dev --filter=ocr-worker",
    "ocr-worker:build": "turbo build --filter=ocr-worker",
    "stt-worker:dev": "turbo dev --filter=stt-worker",
    "stt-worker:build": "turbo build --filter=stt-worker",
    "gen-icons": "turbo gen-icons --filter=core",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx,json,md,yml,yaml,css}": "prettier --write"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "eslint": "9.39.4",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.8",
    "prettier": "^3.9.4",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "turbo": "2.10.3",
    "typescript-config": "workspace:*"
  },
  "packageManager": "pnpm@9.1.4"
}
