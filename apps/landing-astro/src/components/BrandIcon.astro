---
import { cn } from "@/lib/utils";

/** Mono brand glyph recoloured to the product accent (mint = Flow, bittersweet = Suite). */
const BRAND = {
  flow: { src: "/home/flow_icon.png", fill: "bg-secondary" },
  suite: { src: "/home/suite_icon.png", fill: "bg-accent" },
} as const;

interface Props {
  product: "flow" | "suite";
  class?: string;
}

const { product, class: className } = Astro.props;
const b = BRAND[product];
const style = `-webkit-mask-image:url(${b.src});mask-image:url(${b.src});-webkit-mask-size:contain;mask-size:contain;-webkit-mask-repeat:no-repeat;mask-repeat:no-repeat;-webkit-mask-position:center;mask-position:center`;
---

<span aria-hidden="true" class={cn("inline-block h-6 w-6", b.fill, className)} style={style}></span>
