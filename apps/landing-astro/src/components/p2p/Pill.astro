---
import { cn } from "@/lib/utils";

interface Props {
  class?: string;
}

const { class: className } = Astro.props;
---

<span
  class={cn(
    "inline-flex items-center rounded-full border border-[var(--p2p-border)] bg-[var(--p2p-hi)] px-3.5 py-1.5 text-[13px] font-semibold text-[var(--p2p-primary)]",
    className,
  )}
>
  <slot />
</span>
