---
import { cn } from "@/lib/utils";

interface Props {
  class?: string;
}

const { class: className } = Astro.props;
---

<div class={cn("animate-float-slow mx-auto w-full max-w-[280px] lg:max-w-none", className)} data-reveal data-reveal-stagger="3">
  <svg viewBox="0 0 400 380" class="h-auto w-full" role="img" aria-label="AI Stack สามชั้น — Integration, Platform, Infrastructure">
    <rect x="60" y="260" width="280" height="80" rx="14" fill="var(--p2p-hi)" stroke="var(--p2p-primary)" stroke-width="2"></rect>
    <text x="200" y="295" text-anchor="middle" font-family="Inter" font-weight="800" font-size="16" fill="var(--p2p-primary)">INFRASTRUCTURE</text>
    <text x="200" y="315" text-anchor="middle" font-family="Inter" font-size="11" fill="var(--p2p-muted)">Titanicom · Network Evolution</text>

    <rect x="45" y="160" width="310" height="80" rx="14" fill="var(--p2p-secondary)" opacity="0.12" stroke="var(--p2p-secondary)" stroke-width="2"></rect>
    <text x="200" y="195" text-anchor="middle" font-family="Inter" font-weight="800" font-size="16" fill="var(--p2p-secondary)">PLATFORM</text>
    <text x="200" y="215" text-anchor="middle" font-family="Inter" font-size="11" fill="var(--p2p-muted)">Perpos AI ERP · ExWorker</text>

    <rect x="30" y="60" width="340" height="80" rx="14" fill="var(--p2p-primary)" stroke="var(--p2p-primary)" stroke-width="2"></rect>
    <text x="200" y="95" text-anchor="middle" font-family="Inter" font-weight="800" font-size="16" fill="#fff">INTEGRATION</text>
    <text x="200" y="115" text-anchor="middle" font-family="Inter" font-size="11" fill="var(--p2p-hi)">P2P Solutions · Supply · ExCon</text>

    <path d="M200 260 L200 240" stroke="var(--p2p-primary)" stroke-width="2.5" marker-end="url(#p2p-hero-arrow)"></path>
    <path d="M200 160 L200 140" stroke="var(--p2p-primary)" stroke-width="2.5" marker-end="url(#p2p-hero-arrow)"></path>
    <defs>
      <marker id="p2p-hero-arrow" markerWidth="10" markerHeight="10" refX="5" refY="5" orient="auto">
        <path d="M0,0 L10,5 L0,10 Z" fill="var(--p2p-primary)"></path>
      </marker>
    </defs>
  </svg>
</div>
