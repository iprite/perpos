---
import { cn } from "@/lib/utils";

interface Props {
  orientation?: "vertical" | "horizontal";
  class?: string;
}

const { orientation = "horizontal", class: className } = Astro.props;
---

{
  orientation === "horizontal" ? (
    <div class={cn("hidden lg:block", className)} aria-hidden="true">
      <svg viewBox="0 0 1136 60" width="100%" height="60">
        <line
          x1="30"
          y1="30"
          x2="1096"
          y2="30"
          stroke="var(--p2p-primary)"
          stroke-width="2"
          class="flow-path"
        />
        <path d="M1086,22 L1098,30 L1086,38" fill="none" stroke="var(--p2p-primary)" stroke-width="2.5" />
      </svg>
    </div>
  ) : (
    <div class={cn("hidden lg:flex justify-center", className)} aria-hidden="true">
      <svg viewBox="0 0 40 60" width="40" height="60">
        <line x1="20" y1="0" x2="20" y2="48" stroke="var(--p2p-primary)" stroke-width="2" class="flow-path" />
        <path d="M12,38 L20,50 L28,38" fill="none" stroke="var(--p2p-primary)" stroke-width="2.5" />
      </svg>
    </div>
  )
}
