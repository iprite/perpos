---
import { cn } from "@/lib/utils";

interface Props {
  class?: string;
}

const { class: className } = Astro.props;
---

<div
  class={cn(
    "animate-float overflow-hidden rounded-2xl border border-[var(--p2p-border)] bg-white shadow-[var(--p2p-shadow-lift)]",
    className,
  )}
  data-reveal
  data-reveal-stagger="4"
>
  {/* browser chrome */}
  <div class="flex items-center gap-2 border-b border-[var(--p2p-border)] bg-[var(--p2p-alt)] px-3.5 py-2.5">
    <span class="h-2.5 w-2.5 rounded-full bg-[#fca5a5]" aria-hidden="true"></span>
    <span class="h-2.5 w-2.5 rounded-full bg-[#fcd34d]" aria-hidden="true"></span>
    <span class="h-2.5 w-2.5 rounded-full bg-[#86efac]" aria-hidden="true"></span>
    <span class="ml-2 truncate rounded-md bg-white px-2.5 py-1 text-[11px] text-[var(--p2p-muted)]">
      app.perpos.ai/dashboard
    </span>
  </div>

  <div class="flex gap-3 p-3.5 sm:gap-4 sm:p-4">
    {/* sidebar skeleton */}
    <div class="hidden w-16 shrink-0 flex-col gap-2 rounded-lg bg-[var(--p2p-alt)] p-2 sm:flex sm:w-20">
      <div class="h-2.5 w-full rounded bg-[var(--p2p-primary)]"></div>
      <div class="h-2 w-full rounded bg-[#cbd5e1]"></div>
      <div class="h-2 w-full rounded bg-[#cbd5e1]"></div>
      <div class="h-2 w-full rounded bg-[#cbd5e1]"></div>
    </div>

    <div class="min-w-0 flex-1">
      {/* real HTML KPI tiles */}
      <div class="grid grid-cols-3 gap-2 sm:gap-3">
        <div class="min-w-0 rounded-lg bg-[var(--p2p-hi)] px-2.5 py-2.5 sm:px-3">
          <div class="truncate text-[13px] font-extrabold text-[var(--p2p-primary)] sm:text-[15px]">฿2.4M</div>
          <div class="mt-0.5 truncate text-[9px] text-[var(--p2p-muted)] sm:text-[10px]">รายรับเดือนนี้</div>
        </div>
        <div class="min-w-0 rounded-lg bg-[#ecfeff] px-2.5 py-2.5 sm:px-3">
          <div class="truncate text-[13px] font-extrabold text-[var(--p2p-secondary)] sm:text-[15px]">98%</div>
          <div class="mt-0.5 truncate text-[9px] text-[var(--p2p-muted)] sm:text-[10px]">ความแม่นยำ AI</div>
        </div>
        <div class="min-w-0 rounded-lg bg-[#f1f5f9] px-2.5 py-2.5 sm:px-3">
          <div class="truncate text-[13px] font-extrabold text-[#475569] sm:text-[15px]">312</div>
          <div class="mt-0.5 truncate text-[9px] text-[var(--p2p-muted)] sm:text-[10px]">รายการวันนี้</div>
        </div>
      </div>

      {/* SVG line chart */}
      <div class="mt-3">
        <svg viewBox="0 0 324 130" class="h-auto w-full" role="img" aria-label="กราฟแนวโน้มยอดรายรับ">
          <rect x="1" y="1" width="322" height="128" fill="none" stroke="var(--p2p-border)" stroke-width="1"></rect>
          <polyline
            points="0,90 35,60 70,80 105,30 140,50 175,10 210,40 245,0 280,25"
            fill="none"
            stroke="var(--p2p-primary)"
            stroke-width="3"
            stroke-linecap="round"
            stroke-linejoin="round"
          ></polyline>
        </svg>
      </div>
    </div>
  </div>
</div>
