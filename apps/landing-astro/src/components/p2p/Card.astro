---
import { cn } from "@/lib/utils";

interface Props {
  hover?: boolean;
  class?: string;
  [key: `data-${string}`]: string | number | boolean | undefined;
}

const { hover = false, class: className, ...rest } = Astro.props;
---

<div
  class={cn(
    "rounded-2xl border border-[var(--p2p-border)] bg-[var(--p2p-card)] p-5 shadow-[var(--p2p-shadow-card)] sm:p-6",
    hover &&
      "transition-[transform,box-shadow] duration-200 hover:-translate-y-1 hover:shadow-[var(--p2p-shadow-lift)]",
    className,
  )}
  {...rest}
>
  <slot />
</div>
