---
/** Legal page body (privacy/terms) — picks language from localStorage / system,
 *  mirroring the old client LanguageProvider (default Thai, no toggle in the UI).
 *  Vanilla replacement: both languages are rendered server-side; a tiny script
 *  reveals English when the visitor's saved/again system language is English. */
import { legal, type Lang } from "@/lib/legal";

interface Props {
  doc: "privacy" | "terms";
}
const { doc } = Astro.props;

const BTN_PRIMARY =
  "group/btn inline-flex items-center justify-center gap-2 whitespace-nowrap rounded-xl px-5 py-2.5 text-sm font-medium bg-primary text-white shadow-xs shadow-primary/25 transition-all duration-200 hover:bg-primary-dark hover:shadow-lg hover:shadow-primary/30 active:scale-[0.98]";

const isPrivacy = doc === "privacy";
const sectionKeys = isPrivacy
  ? [
      ["section1Title", "section1Desc"],
      ["section2Title", "section2Desc"],
      ["section3Title", "section3Desc"],
      ["section4Title", "section4Desc"],
      ["section5Title", "section5Desc"],
      ["section6Title", "section6Desc"],
    ]
  : [
      ["section1Title", "section1Desc"],
      ["section2Title", "section2Desc"],
      ["section3Title", "section3Desc"],
      ["section4Title", "section4Desc"],
      ["section5Title", "section5Desc"],
      ["section6Title", "section6Desc"],
    ];
const contactTitleKey = "section7Title";
const contactDescKey = "section7Desc";

function build(lang: Lang) {
  const dict = legal[lang];
  const p = (isPrivacy ? dict.privacyPage : dict.termsPage) as Record<
    string,
    string
  >;
  return {
    t: p,
    sections: sectionKeys.map(([tk, dk]) => ({ title: p[tk], desc: p[dk] })),
    contactTitle: p[contactTitleKey],
    contactDesc: p[contactDescKey],
  };
}

const langs: Lang[] = ["th", "en"];
---

{
  langs.map((lang) => {
    const d = build(lang);
    return (
      <article
        class:list={[
          "mx-auto max-w-3xl px-5 py-16 sm:px-6 md:py-20 lg:px-8",
          lang === "en" && "hidden",
        ]}
        data-legal-lang={lang}
      >
        <h1 class="text-foreground text-3xl font-semibold tracking-tight sm:text-4xl">
          {d.t.title}
        </h1>
        <p class="text-foreground-muted mt-3 text-sm">{d.t.lastUpdated}</p>

        <div class="mt-10 space-y-8">
          {d.sections.map((s) => (
            <section>
              <h2 class="text-foreground text-lg font-semibold">{s.title}</h2>
              <p class="text-foreground-secondary mt-2 leading-7">{s.desc}</p>
            </section>
          ))}
          <section>
            <h2 class="text-foreground text-lg font-semibold">
              {d.contactTitle}
            </h2>
            <p class="text-foreground-secondary mt-2 leading-7">
              {d.contactDesc}{" "}
              <a href="mailto:contact@perpos.ai" class="text-primary underline">
                contact@perpos.ai
              </a>
            </p>
          </section>
        </div>

        <div class="mt-12">
          <a href="https://app.perpos.ai/signin" class={BTN_PRIMARY}>
            {d.t.signupCta}
          </a>
        </div>
      </article>
    );
  })
}

<script>
  // Default Thai (rendered visible). Switch to English only when the visitor
  // explicitly saved "en" or their browser language is English.
  const saved = localStorage.getItem("lang");
  const useEn =
    saved === "en" ||
    (saved !== "th" && navigator.language.toLowerCase().startsWith("en"));
  if (useEn) {
    document
      .querySelector('[data-legal-lang="th"]')
      ?.classList.add("hidden");
    document
      .querySelector('[data-legal-lang="en"]')
      ?.classList.remove("hidden");
  }
</script>
